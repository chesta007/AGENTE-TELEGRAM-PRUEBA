# ==============================================================
# ALCANCE AI — Variables de Entorno
# Copia este archivo como .env y completa los valores reales
# ¡NUNCA commitees el .env real al repositorio!
# ==============================================================

# ── TELEGRAM ──────────────────────────────────────────────────
# Token de tu bot creado en @BotFather
TELEGRAM_TOKEN="tu_token_de_botfather"

# ── LLM PROVIDER ─────────────────────────────────────────────
# Proveedor: OpenRouter (openrouter.ai)
OPENROUTER_API_KEY="sk-or-v1-..."

# ── SUPABASE ──────────────────────────────────────────────────
# URL pública del proyecto Supabase
VITE_SUPABASE_URL="https://xxxxxxxx.supabase.co"

# Anon Key: usada por el FRONTEND (Vite la inyecta en el bundle)
# Es pública, pero RLS debe estar bien configurado
VITE_SUPABASE_ANON_KEY="eyJhbGciOiJI..."

# Service Role Key: usada SOLO por el BOT (Node.js)
# Bypasea RLS — ¡NUNCA exponer al frontend!
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOiJI..."

# ── SERVIDOR ──────────────────────────────────────────────────
# Puerto del servidor Express (Railway lo provee automáticamente)
PORT=3000

# URL pública del servidor (para webhooks de Telegram y WhatsApp)
APP_URL="https://tu-app.railway.app"

# ── SEGURIDAD ─────────────────────────────────────────────────
# Token secreto para proteger los endpoints del dashboard (/api/*)
# Genera uno con: openssl rand -hex 32
DASHBOARD_SECRET="genera_una_clave_aleatoria_larga"

# ── DEBUG (OPCIONAL) ──────────────────────────────────────────
# Activar logs de debug en desarrollo
# DEBUG=true

# ── EVOLUTION API (WHATSAPP) ──────────────────────────────────
# Requerido para enviar respuestas por WhatsApp
EVOLUTION_URL="https://tu-evolution.com"
EVOLUTION_API_KEY="apikey_del_servidor"
